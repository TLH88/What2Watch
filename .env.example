# What2Watch - Environment Configuration
# Copy this file to .env and fill in your own values.
# Do not commit your real .env file.

# App
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql+asyncpg://what2watch:what2watch@db:5432/what2watch
POSTGRES_USER=what2watch
POSTGRES_PASSWORD=what2watch
POSTGRES_DB=what2watch

# TMDB
TMDB_API_KEY=your_tmdb_api_key

# Trakt
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# Jellyfin
JELLYFIN_URL=
JELLYFIN_API_KEY=

# AI Provider: openai | anthropic | google
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
