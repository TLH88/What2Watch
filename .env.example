# What2Watch - Environment Configuration
# Copy this file to .env and fill in your values

# App
DEBUG=false
SECRET_KEY=change-me-to-a-random-string

# Database
DATABASE_URL=postgresql+asyncpg://what2watch:what2watch@db:5432/what2watch
POSTGRES_USER=what2watch
POSTGRES_PASSWORD=what2watch
POSTGRES_DB=what2watch

# TMDB
TMDB_API_KEY=

# Trakt
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# Jellyfin
JELLYFIN_URL=
JELLYFIN_API_KEY=

# AI Provider: openai | anthropic | google
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
